# Variables de entorno para desarrollo local
# Railway provee DATABASE_URL automáticamente — no necesitás cambiar nada en producción

# Opción A: URL completa (Railway la pone automáticamente)
# DATABASE_URL=postgresql://user:pass@host:port/dbname

# Opción B: Variables individuales (desarrollo local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=prospectai
DB_USER=postgres
DB_PASSWORD=tu_password

FLASK_ENV=development
